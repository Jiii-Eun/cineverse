# TMDB API (https://www.themoviedb.org/settings/api 에서 발급)
EXPO_PUBLIC_TMDB_API_KEY=your_tmdb_api_key_here
EXPO_PUBLIC_TMDB_BASE_URL=https://api.themoviedb.org/3
EXPO_PUBLIC_TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
EXPO_PUBLIC_TMDB_LANGUAGE=ko-KR
EXPO_PUBLIC_TMDB_REGION=KR

# 로컬 웹 개발 시 TMDB가 localhost redirect를 차단합니다.
# ngrok 등 공개 URL을 쓸 때만 설정하세요. 예: https://xxxx.ngrok-free.app/auth/callback
# EXPO_PUBLIC_AUTH_CALLBACK_URL=
